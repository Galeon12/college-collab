# Frontend build-time config. Copy to .env at the repo ROOT.
#
# Vite inlines every VITE_* value into the bundle, so these are all PUBLIC.
# Never put a secret here. Secrets belong in server/.env.
#
# These are compiled in, not read at runtime: changing any of them requires a
# rebuild (`make deploy`), not just a restart.

# The site's own origin. nginx serves the frontend and proxies /api to Node on the
# same host, so this is the site URL itself -- NOT a separate API hostname.
#
# No trailing slash: the code builds `${VITE_API_URL}/api/...`, so a trailing slash
# produces `//api/...`.
#
# This must be byte-for-byte identical to ALLOWED_ORIGINS in server/.env. Browsers
# send an Origin header on every POST even same-origin, so a mismatch means the page
# loads perfectly and every login and submit 403s. `make preflight` refuses to deploy
# if they disagree.
VITE_API_URL=https://apply.yourdomain.com

# Auth0 (public identifiers)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id

# Google reCAPTCHA v2 "I'm not a robot" -- SITE key (the public half of the pair).
# Generate at https://www.google.com/recaptcha/admin/create
VITE_RECAPTCHA_SITE_KEY=

# Acknowledgement email to the applicant, sent via EmailJS after a successful submit.
# Defaults to ON. Set to false to deploy without EmailJS at all: the three ids below are
# then not required and no email is sent. The application is saved either way.
# VITE_EMAIL_ACK_ENABLED=false

# EmailJS (public identifiers). Required unless VITE_EMAIL_ACK_ENABLED=false.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
