# Backend secrets. The server refuses to boot if any required value is missing.
# Copy to server/.env and fill in. This file is read by dotenv relative to the
# process's working directory, which is why pm2 sets cwd to server/.

# NODE_ENV is the most load-bearing line in this file. It gates, all at once:
#   - ALLOWED_ORIGINS being required at all
#   - `trust proxy` (without it every client looks like nginx and the rate
#     limiters bucket the whole internet into one counter)
#   - the spool refusing to boot when its directory is unwritable
#   - whether CORS quietly accepts any localhost origin
# Set to anything else and the server boots "fine" with all four silently off.
NODE_ENV=production

# The port Node listens on, on loopback only. nginx proxies /api to it, so this
# MUST match proxy_pass in the vhost. The VM runs other services -- pick a port
# nothing else has taken (`make preflight` checks).
PORT=5000

# Exact origins allowed to call this API, comma-separated. Required in production.
#
# This MUST contain the site's own origin, byte for byte, even though the API is
# served from that same origin. Browsers send an Origin header on every non-GET
# request, and every call this frontend makes is a POST -- so same-origin does NOT
# bypass CORS. Get this wrong and the site renders perfectly while every login and
# every submit returns 403.
#
# It must be the identical string as VITE_API_URL in the root .env. `make preflight`
# refuses to deploy if they disagree.
ALLOWED_ORIGINS=https://apply.yourdomain.com

# Signs session JWTs.            Generate: openssl rand -hex 32
JWT_SECRET=

# Gates GET /api/applications and /api/health, which return applicant PII.
# Sent by the caller as the `x-admin-key` header.
# Generate: openssl rand -hex 32
ADMIN_API_KEY=

# Google reCAPTCHA v2 -- SECRET key (the private half of the pair whose site key
# is VITE_RECAPTCHA_SITE_KEY). https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET=

# Auth0 tenant domain, used to fetch the JWKS that verifies Google sign-ins.
AUTH0_DOMAIN=your-tenant.us.auth0.com

# Airtable. The PAT needs data.records:read + data.records:write on this base.
# Confirm the COLUMN NAMES match server/db/airtable.js before going live: a
# mismatch is a 422, which is permanent, so the submission is dead-lettered while
# the applicant is shown a success message.
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_USERS=Users
AIRTABLE_TABLE_APPLICATIONS=Applications

# ---------------------------------------------------------------------------
# The only two optional knobs. Both have working defaults -- leave them unset
# unless you have a reason. Retry and spool behaviour is otherwise constants in
# code (server/db/retry.js, server/db/drain.js), not configuration.
# ---------------------------------------------------------------------------

# Per-request Airtable timeout. The SDK's own default is 300s, which is not a
# timeout but a hang. Raise this if Airtable is slow.
#
# Setting it to 1 is also the fault injection used to prove the spool works
# end-to-end on the real box: every Airtable call then times out, so a submit
# returns 202 and lands in failed-writes.jsonl instead of Airtable.
# AIRTABLE_TIMEOUT_MS=10000

# Where failed writes are parked until the drainer lands them in Airtable, so a
# submission is never lost. Defaults to /var/lib/college-collab/spool in
# production and server/.data in development.
#
# It lives OUTSIDE the git checkout on purpose: when Airtable is down this file
# is the only copy of an applicant's submission, and anything inside the repo is
# one `git clean -xdf` away from deletion. `make setup` creates it. The server
# REFUSES TO BOOT in production if it is not writable.
# SPOOL_DIR=/var/lib/college-collab/spool
